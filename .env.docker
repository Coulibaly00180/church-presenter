# Variables pour docker-compose.local.yml (test local uniquement)
# Ne pas committer si vous changez les mots de passe

POSTGRES_USER=church
POSTGRES_PASSWORD=church
POSTGRES_DB=church_presenter

DATABASE_URL=postgresql://church:church@db:5432/church_presenter

NEXTAUTH_SECRET=local-dev-secret-not-for-production
AUTH_SECRET=local-dev-secret-not-for-production
NEXTAUTH_URL=http://localhost:3000

# Compte admin créé au premier démarrage
ADMIN_EMAIL=admin@church.local
ADMIN_PASSWORD=admin1234
