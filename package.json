{
  "name": "church-presenter",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @cp/desktop",
    "build": "npm run build -w @cp/desktop",
    "dist:win": "npm run dist:win -w @cp/desktop",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "web:dev": "npm run dev -w @cp/web",
    "web:build": "npm run build -w @cp/web"
  }
}
