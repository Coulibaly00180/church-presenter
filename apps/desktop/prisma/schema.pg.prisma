generator pgClient {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/pg-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_PG")
}

model Song {
  id        String    @id @default(cuid())
  title     String
  artist    String?
  album     String?
  year      String?
  language  String?
  tags      String?   // JSON-as-TEXT (SQLite compat — pas String[] natif)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  blocks    SongBlock[]
  planItems ServiceItem[] @relation("ServiceItemSong")
}

model SongBlock {
  id        String   @id @default(cuid())
  songId    String
  order     Int
  type      String
  title     String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([songId, order])
  @@index([songId, order])
}

model ServicePlan {
  id               String    @id @default(cuid())
  date             DateTime  @unique
  title            String?
  backgroundConfig String?   // JSON-as-TEXT
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  items ServiceItem[]
}

model ServiceItem {
  id               String  @id @default(cuid())
  planId           String
  order            Int
  kind             String
  refId            String?
  refSubId         String?
  songId           String?
  title            String?
  content          String?
  notes            String?
  mediaPath        String?
  secondaryContent String?  // JSON-as-TEXT
  backgroundConfig String?  // JSON-as-TEXT
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  plan ServicePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  song Song?       @relation("ServiceItemSong", fields: [songId], references: [id], onDelete: SetNull)

  @@unique([planId, order])
  @@index([planId, order])
  @@index([songId])
}
